{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user/partner in the scheduling application.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique user ID." },
        "name": { "type": "string", "description": "The full name of the user." },
        "code": { "type": "string", "description": "Initials/abbreviation of the user." },
        "color": { "type": "string", "description": "HEX color associated with the user." },
        "isAdmin": { "type": "boolean", "description": "Whether the user has admin privileges." }
      },
      "required": ["id", "name", "code", "color", "isAdmin"]
    },
    "Location": {
      "title": "Location",
      "description": "Represents a shop/boutique location with custom schedules.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique location ID." },
        "name": { "type": "string", "description": "The name of the location." },
        "code": { "type": "string", "description": "Short code of the location." },
        "color": { "type": "string", "description": "Visual style theme code." },
        "dates": { "type": "array", "description": "Array of active dates (YYYY-MM-DD)." }
      },
      "required": ["id", "name", "code", "color", "dates"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "Represents a reservation for a partner at a specific location on a specific date.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique reservation ID." },
        "userId": { "type": "string", "description": "The ID of the user who made the reservation." },
        "userName": { "type": "string", "description": "The name of the user." },
        "locationId": { "type": "string", "description": "The location ID where the reservation is made." },
        "date": { "type": "string", "description": "The date of reservation (YYYY-MM-DD)." },
        "hours": { "type": "number", "description": "Number of hours reserved." },
        "hourlyRate": { "type": "number", "description": "Hourly rate for this reservation." }
      },
      "required": ["id", "userId", "userName", "locationId", "date", "hours", "hourlyRate"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application configuration settings.",
      "type": "object",
      "properties": {
        "maxPartnersPerDay": { "type": "number", "description": "Maximum number of partners allowed per day." },
        "defaultHourlyRate": { "type": "number", "description": "Default hourly rate in euros." },
        "defaultHoursPerDay": { "type": "number", "description": "Default hours per day for a standard shift." }
      },
      "required": ["maxPartnersPerDay", "defaultHourlyRate", "defaultHoursPerDay"]
    },
    "NotificationLog": {
      "title": "NotificationLog",
      "description": "Represents a log entry for notifications/activities in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique notification ID." },
        "timestamp": { "type": "string", "description": "ISO timestamp of the event." },
        "message": { "type": "string", "description": "The notification message text." },
        "type": { "type": "string", "description": "Type of notification (info, success, warning)." },
        "userId": { "type": "string", "description": "Optional user ID related to the notification." }
      },
      "required": ["id", "timestamp", "message", "type"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of planning users/partners."
    },
    "locations/{locationId}": {
      "schema": "Location",
      "description": "Collection of shop locations."
    },
    "reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Collection of booking/planning reservations."
    },
    "settings/app_settings": {
      "schema": "AppSettings",
      "description": "Global app settings document."
    },
    "notifications/{notificationId}": {
      "schema": "NotificationLog",
      "description": "Collection of activity log entries."
    }
  }
}
